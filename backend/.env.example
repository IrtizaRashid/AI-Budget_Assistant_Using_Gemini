# ---- Server ----
PORT=5001
NODE_ENV=development

# Allowed frontend origin(s) for CORS (comma-separated).
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ---- Supabase Postgres ----
# Use the Supabase Transaction pooler connection string, port 6543.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# ---- Supabase Auth ----
# Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Google Gemini (AI provider) ----
# Users save their own keys in the app. This optional fallback is only for admin/local testing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
