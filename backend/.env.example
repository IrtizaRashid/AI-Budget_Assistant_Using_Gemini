# ---- Server ----
PORT=5001
NODE_ENV=development

# Allowed frontend origin(s) for CORS (comma-separated).
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ---- MySQL Database ----
# Local MySQL defaults to port 3306. Railway provides its own host/port/creds.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=budget_ai

# ---- Groq (AI provider, free) ----
# Get a free API key at https://console.groq.com (no credit card).
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
