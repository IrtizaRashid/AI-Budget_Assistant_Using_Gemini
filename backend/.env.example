# ---- Server ----
PORT=5001
NODE_ENV=development

# Allowed frontend origin(s), comma-separated.
CORS_ORIGIN=http://localhost:5173

# ---- Supabase Postgres ----
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# ---- Supabase Auth ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Google Gemini provider ----
# Put all Gemini keys here, separated by commas.
GEMINI_API_KEY=
GEMINI_API_KEYS=gemini_key_1,gemini_key_2,gemini_key_3
GEMINI_MODEL=gemini-3-flash-preview

# ---- Groq provider ----
# Groq keys usually start with gsk_. Put them here, separated by commas.
GROQ_API_KEYS=groq_key_1,groq_key_2,groq_key_3
GROQ_MODEL=llama-3.3-70b-versatile

# ---- OpenRouter fallback provider ----
OPENROUTER_API_KEYS=openrouter_key_1,openrouter_key_2
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-frontend-vercel-url.vercel.app
OPENROUTER_APP_TITLE=Budget AI
