# ---- Server ----
PORT=5001

# ---- MySQL Database ----
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=budget_ai

# ---- Groq (AI provider, free) ----
# Get a free API key at https://console.groq.com (no credit card).
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL is optional (defaults to https://api.groq.com/openai/v1).
